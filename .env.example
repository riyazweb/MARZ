# Copy this file to .env and fill in your API keys

# Required — Mistral AI (get from https://console.mistral.ai)
MISTRAL_API_KEY=your_mistral_api_key_here

# Optional — ElevenLabs TTS (get from https://elevenlabs.io)
# If not set, aliens will respond without voice
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional — ElevenLabs Voice IDs (defaults are already set in code)
ELEVENLABS_VOICE_ALIEN1=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_VOICE_ALIEN2=EXAVITQu4vr4xnSDxMaL

# Optional — Mem0 memory (currently disabled in-game)
MEM0_API_KEY=your_mem0_api_key_here

# Optional — CORS origin for deployed version (e.g. https://your-app.railway.app)
ALLOWED_ORIGIN=
